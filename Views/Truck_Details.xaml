<Window x:Class="Scada_Demo.Views.Truck_Details"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Truck Details"
        Height="500" Width="800"
        Background="{StaticResource PrimaryBgBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="15">

        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                Padding="20"
                CornerRadius="10">

            <Grid>

                <!-- LAYOUT -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TITLE -->
                <TextBlock Text="Truck Details"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- FORM -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <!-- LABELS -->
                    <TextBlock Text="Truck Reg No" Grid.Row="0" Style="{StaticResource LabelStyle}" />
                    <TextBlock Text="Driver" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="Capacity" Grid.Row="2" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="Type of Truck" Grid.Row="3" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="Mixer Gate Timer" Grid.Row="4" Style="{StaticResource LabelStyle}"/>

                    <!-- INPUTS -->

                    <!-- SYSTEM FIELD -->
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              Style="{StaticResource SystemFieldComboBox}"/>

                    <!-- 🔥 BLACK (Editable important fields) -->
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource SystemFieldTextBox}"/>

                    <TextBox Grid.Row="2" Grid.Column="1"
                             Style="{StaticResource SystemFieldTextBox}"/>

                    <!-- NORMAL WHITE -->
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Style="{StaticResource SystemFieldTextBox}"/>

                    <!-- 🔥 BLACK -->
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Style="{StaticResource SystemFieldTextBox}"/>

                </Grid>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">

                    <Button Content="SAVE" Width="90"/>
                    <Button Content="DELETE" Width="90"/>
                    <Button Content="EXIT" Width="90"/>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>