<Window x:Class="Scada_Demo.DashboardPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#0F2A2A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="📊 DASHBOARD" 
                   Foreground="#00FFFF" 
                   FontSize="24" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Production -->
        <Border Grid.Row="1" Background="#134646" CornerRadius="5" Padding="15" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🏭" FontSize="30" Margin="0,0,15,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Total Production" Foreground="White" FontSize="14"/>
                    <TextBlock Text="1,245 m³" Foreground="#00FFFF" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Active Orders -->
        <Border Grid.Row="2" Background="#134646" CornerRadius="5" Padding="15" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="📋" FontSize="30" Margin="0,0,15,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Active Orders" Foreground="White" FontSize="14"/>
                    <TextBlock Text="8" Foreground="#00FFFF" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Mixer Status -->
        <Border Grid.Row="3" Background="#134646" CornerRadius="5" Padding="15" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚙️" FontSize="30" Margin="0,0,15,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Mixer Status" Foreground="White" FontSize="14"/>
                    <TextBlock Text="RUNNING" Foreground="LimeGreen" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Close Button -->
        <Button Grid.Row="4" 
                Content="Close" 
                Width="100" 
                Height="35"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Background="#B22222" 
                Foreground="White" 
                FontWeight="Bold"
                Click="CloseButton_Click"/>
    </Grid>
</Window>