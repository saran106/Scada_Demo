<Window x:Class="Scada_Demo.Views.Schedule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCI460 Schedule Master"
        Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBgBrush}">

    <Border Margin="10"
            BorderBrush="{StaticResource BorderBrushColor}"
            BorderThickness="2"
            CornerRadius="8"
            Background="{StaticResource PanelBrush}">

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Schedule Configuration"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryText}"
                       Margin="10"/>

            <!-- Form Section -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <!-- Labels -->
                <TextBlock Text="Schedule ID" Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="Schedule Date" Grid.Row="1" Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="Schedule Type" Grid.Row="2" Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="Time settings (HH:MM)" Grid.Row="3" Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>

                <!-- Inputs -->
                <ComboBox Grid.Column="1" Margin="5"/>
                <DatePicker Grid.Row="1" Grid.Column="1" Margin="5"/>
                <ComboBox Grid.Row="2" Grid.Column="1" Margin="5">
                    <ComboBoxItem Content="No Schedule"/>
                </ComboBox>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="5"/>
            </Grid>

            <!-- List Section -->
            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Available -->
                <StackPanel>
                    <TextBlock Text="Available order list"
                               Foreground="{StaticResource PrimaryText}"
                               Margin="5"/>
                    <ListBox Height="200"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="&gt;" Margin="5" Height="40"
                            Background="{StaticResource ButtonBg}"
                            Foreground="{StaticResource ButtonText}"/>
                    <Button Content="&lt;" Margin="5" Height="40"
                            Background="{StaticResource ButtonBg}"
                            Foreground="{StaticResource ButtonText}"/>
                </StackPanel>

                <!-- Selected -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Selected order list"
                               Foreground="{StaticResource PrimaryText}"
                               Margin="5"/>
                    <ListBox Height="200"/>
                </StackPanel>
            </Grid>

            <!-- Bottom Buttons -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="10">

                <Button Content="DELETE" Width="100" Margin="10"
                        Background="{StaticResource ButtonBg}"
                        Foreground="{StaticResource ButtonText}"/>

                <Button Content="SAVE" Width="100" Margin="10"
                        Background="{StaticResource ButtonBg}"
                        Foreground="{StaticResource ButtonText}"/>

                <Button Content="EXIT" Width="100" Margin="10"
                        Background="{StaticResource ButtonBg}"
                        Foreground="{StaticResource ButtonText}"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>