<Window x:Class="Scada_Demo.Views.Configuration_Order"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration_Order"
        Height="600" Width="950"
        Background="{StaticResource PrimaryBgBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <!-- ================= STYLES ================= -->
    <Window.Resources>

        <!-- LABEL -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 🔥 BLACK INPUT -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding" Value="6"/>
        </Style>

        <!-- 🔥 COMBO -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
        </Style>

        <!-- BUTTON -->
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#002F2F"/>
            <Setter Property="Foreground" Value="#00FFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

    </Window.Resources>

    <!-- ================= UI ================= -->
    <Grid Margin="10">

        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                Padding="15"
                CornerRadius="8">

            <Grid>

                <Grid.RowDefinitions>   
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <TextBlock Text="Configure Order"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryText}"
                           Margin="5"/>

                <!-- ================= FORM ================= -->
                <Grid Grid.Row="1" Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <Grid Grid.Column="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Order Id" Grid.Row="0" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Order Date" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Customer Id" Grid.Row="2" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Recipe ID" Grid.Row="3" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Site" Grid.Row="4" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Truck ID" Grid.Row="5" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Ordered Qty" Grid.Row="6" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Production Qty" Grid.Row="7" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Adjust Qty" Grid.Row="8" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Load Sent Qty" Grid.Row="9" Style="{StaticResource LabelStyle}"/>

                        <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ComboStyle}"/>
                        <DatePicker Grid.Row="1" Grid.Column="1" Margin="0,5"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource ComboStyle}"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" Style="{StaticResource ComboStyle}"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource ComboStyle}"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" Style="{StaticResource ComboStyle}"/>

                        <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="9" Grid.Column="1" Style="{StaticResource InputStyle}"/>

                    </Grid>

                    <!-- RIGHT -->
                    <Grid Grid.Column="1" Margin="20,0,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Aggregate Used" Grid.Row="0" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Cement Used" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Water Used" Grid.Row="2" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Admixture Used" Grid.Row="3" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Special Note" Grid.Row="4" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Order Type" Grid.Row="5" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Job Number" Grid.Row="6" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Account Number" Grid.Row="7" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Max Cement" Grid.Row="8" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Water Ratio" Grid.Row="9" Style="{StaticResource LabelStyle}"/>

                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="9" Grid.Column="1" Style="{StaticResource InputStyle}"/>

                    </Grid>

                </Grid>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15">

                    <Button Content="SAVE"  Style="{StaticResource GreenButton}" Width="100"/>
                    <Button Content="DELETE"  Width="100"/>
                    <Button Content="EXIT"  Width="100"/>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>