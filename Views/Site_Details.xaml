<Window x:Class="Scada_Demo.Views.Site_Details"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scada_Demo.Views"
        mc:Ignorable="d"
        Title="Site_Details" Height="450" Width="800">
    <Grid>
        <Grid Background="#0F2A2A" Margin="10">

            <!-- STYLES -->
            <Grid.Resources>

                <!-- Label -->
                <Style x:Key="LabelStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="#00FFFF"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="0,6"/>
                </Style>

                <!-- Input -->
                <Style x:Key="InputStyle" TargetType="TextBox">
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="Margin" Value="0,5"/>
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#00FFFF"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Style>

                <!-- Combo -->
                <Style TargetType="ComboBox">
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="Margin" Value="0,5"/>
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#00FFFF"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Style>

                <!-- Button -->
                <Style x:Key="BtnStyle" TargetType="Button">
                    <Setter Property="Width" Value="120"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="#0B1F1F"/>
                    <Setter Property="Foreground" Value="#00FFFF"/>
                    <Setter Property="BorderBrush" Value="#00FFFF"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="Margin" Value="10"/>
                </Style>

            </Grid.Resources>

            <!-- CARD -->
            <Border Background="#134646"
            BorderBrush="#00FFFF"
            BorderThickness="1.5"
            CornerRadius="8"
            Padding="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <TextBlock Text="Site Details"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#00FFFF"
                       Margin="5"/>

                    <!-- FORM -->
                    <Grid Grid.Row="1" Margin="5">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- LABELS -->
                        <TextBlock Text="Customer ID" Grid.Row="0" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Site" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Address" Grid.Row="2" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="3"/>
                        <TextBlock Grid.Row="4"/>
                        <TextBlock Text="City" Grid.Row="5" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Pincode" Grid.Row="6" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Phone" Grid.Row="7" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Contact" Grid.Row="8" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="Distance" Grid.Row="9" Style="{StaticResource LabelStyle}"/>

                        <!-- INPUTS -->
                        <ComboBox Grid.Row="0" Grid.Column="1"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"/>

                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource InputStyle}"/>

                        <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource InputStyle}"/>
                        <TextBox Grid.Row="9" Grid.Column="1" Style="{StaticResource InputStyle}"/>

                    </Grid>

                    <!-- BUTTONS -->
                    <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="SAVE" Style="{StaticResource BtnStyle}"/>
                        <Button Content="DELETE" Style="{StaticResource BtnStyle}"/>
                        <Button Content="EXIT" Style="{StaticResource BtnStyle}"/>

                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
