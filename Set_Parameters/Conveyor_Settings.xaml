<Window x:Class="Scada_Demo.Set_Parameters.Conveyor_Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conveyor_Settings"
        Height="500" Width="650"
        Background="#0D3A3A" WindowStartupLocation="CenterScreen">

    <Grid Margin="8">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Conveyor Settings"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1 -->
                <TextBlock Text="Conveyor on delay for material discharge in sec"
                           Grid.Row="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

                <!-- 2 -->
                <TextBlock Text="Ascending hooter on delay in sec"
                           Grid.Row="1"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="1" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

                <!-- 3 -->
                <TextBlock Text="Conveyor on delay while batching in sec"
                           Grid.Row="2"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

                <!-- 4 -->
                <TextBlock Text="Trigger conveyor on while batching bin no"
                           Grid.Row="3"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="3" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

                <!-- 5 -->
                <TextBlock Text="Trigger conveyor on while reaching actual weight in kg"
                           Grid.Row="4"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="4" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

                <!-- 6 -->
                <TextBlock Text="Ascending conveyor material transfer time in sec"
                           Grid.Row="5"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="5" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Read from PLC" Width="150" Margin="8"/>
            <Button Content="Write to PLC / DB" Width="180" Margin="8"/>
            <Button Content="Exit"
                    Width="110"
                    Margin="8"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>