<Window x:Class="Scada_Demo.Set_Parameters.Moisture_Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scada_Demo.Set_Parameters"
        mc:Ignorable="d"
        Title="Moisture_Settings"         Height="450" Width="600"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <TextBlock Text="Mositure Settings"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- ================= CONTENT ================= -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <!-- Label -->
                    <ColumnDefinition Width="20"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Input -->
                </Grid.ColumnDefinitions>

                <!-- 🔥 CHANGE HERE -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

               

                <!-- 2 -->
                <TextBlock Text="Auto Moisture"
                           Grid.Row="1"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <ComboBox Grid.Row="1" Grid.Column="2"
          Height="34"
          Width="180"
          VerticalAlignment="Center"
          Margin="0,6"/>

             

               
                <!-- 3 -->
                <TextBlock Text="Bin Configuration for first mositure"
                           Grid.Row="4"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="4" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"
                         Text="0"/>

                <!-- 4 -->
                <TextBlock Text="Bin Configuration for second mositure"
                           Grid.Row="5"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="5" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"
                         Text="1"/>

                <!-- 5 -->
                <TextBlock Text="Start weight for moisture calculation in kg"
                           Grid.Row="6"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="6" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"
                         IsReadOnly="True"
                         Text="0"/>

                <!-- 6 -->
                <TextBlock Text="Stop weight for moisture calculation in kg"
            Grid.Row="3"
            VerticalAlignment="Center"
            Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="3" Grid.Column="2"
          Style="{StaticResource JogTextBoxStyle}"
          Height="34"/>


            </Grid>
        </Border>

        <!-- ================= BUTTONS ================= -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Read from PLC"
                    Width="150"
                    Margin="8"/>

            <Button Content="Write to PLC / DB"
                    Width="180"
                    Margin="8"/>

            <Button Content="Exit"
                    Width="110"
                    Margin="8"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>
