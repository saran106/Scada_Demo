<Window x:Class="Scada_Demo.Set_Parameters.Skip_Paramter_Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skip_Paramter_Settings"
        Height="450" Width="600"
Background="#0D3A3A" 
        WindowStartupLocation="CenterScreen">
    <Grid Margin="8">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <TextBlock Text="Skip Parameter Settings"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- ================= CONTENT ================= -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <!-- Label -->
                    <ColumnDefinition Width="20"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Input -->
                </Grid.ColumnDefinitions>

                <!-- 🔥 CHANGE HERE -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1 -->
                <TextBlock Text="Skip discharge time in sec"
                           Grid.Row="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="0" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

            
                <!-- 2 -->
                <TextBlock Text="Skip up delay time in sec"
                           Grid.Row="2"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="2" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"
                         Text="10"/>

                <!-- 3 -->
                <TextBlock Text="Skip run time in sec"
                           Grid.Row="3"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="3" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"/>

                <!-- 4 -->
                <TextBlock Text="Slack steel rope settling time in msec"
                           Grid.Row="4"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="4" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"
                         Text="0"/>

                <!-- 5 -->
                <TextBlock Text="Slack steel rope alert trigger time in sec"
                           Grid.Row="5"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="5" Grid.Column="2"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34"
                         Text="1"/>

             

            </Grid>
        </Border>

        <!-- ================= BUTTONS ================= -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Read from PLC"
                    Width="150"
                    Margin="8"/>

            <Button Content="Write to PLC / DB"
                    Width="180"
                    Margin="8"/>

            <Button Content="Exit"
                    Width="110"
                    Margin="8"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>