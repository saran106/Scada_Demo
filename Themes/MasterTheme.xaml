    <Style x:Key="CompactComboBoxSmall"
      TargetType="ComboBox"
      BasedOn="{StaticResource SystemFieldComboBox}">

        <!-- SIZE -->
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Width" Value="220"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>

        <!-- SPACING -->
        <Setter Property="Margin" Value="6,8"/>
        <Setter Property="Padding" Value="6,2"/>

        <!-- COLORS -->
        <Setter Property="Background" Value="Black"/>
        <Setter Property="Foreground" Value="White"/>

        <!-- BORDER -->
        <Setter Property="BorderBrush" Value="White"/>
        <Setter Property="BorderThickness" Value="2.5"/>

        <!-- EDITABLE -->
        <Setter Property="IsEditable" Value="True"/>
        <Setter Property="IsTextSearchEnabled" Value="True"/>
        <Setter Property="IsTextSearchCaseSensitive" Value="False"/>
        <Setter Property="StaysOpenOnEdit" Value="True"/>

        <!-- 🔥 TEXTBOX INSIDE COMBO FIX -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>

                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           Background="{TemplateBinding Background}"
                           CornerRadius="3">

                            <Grid>
                                <!-- TEXTBOX -->
                                <TextBox x:Name="PART_EditableTextBox"
                                    Background="Black"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="6,2"
                                    CaretBrush="White"/>

                                <!-- DROPDOWN BUTTON -->
                                <ToggleButton Grid.Column="1"
                                         Width="25"
                                         HorizontalAlignment="Right"
                                         Background="#333"
                                         BorderBrush="White"
                                         BorderThickness="1"
                                         Focusable="False"
                                         IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                     Fill="White"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                                </ToggleButton>
                            </Grid>

                        </Border>

                        <!-- DROPDOWN -->
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                          Placement="Bottom"
                          AllowsTransparency="True"
                          Focusable="False"
                          PopupAnimation="Slide">

                            <Border Background="Black"
                               BorderBrush="White"
                               BorderThickness="1">
                                <ScrollViewer>
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>

                        </Popup>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- DROPDOWN ITEMS -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Black"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="6"/>

                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#333"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#555"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>

    </Style>

    <!-- 🔥 HEADER STYLE (SOFT GLOW) -->
    <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>

        <!-- 🔥 COLOR -->
        <Setter Property="Foreground" Value="#00FFFF"/>

        <!-- 🔥 SOFT GLOW (REDUCED) -->
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00FFFF"
                              BlurRadius="4"   
                    ShadowDepth="0"
                              Opacity="0.6"/>
                    <!-- 🔽 softer -->
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabButtonStyle" TargetType="Button">

        <!-- SIZE -->
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <!-- TEXT -->
        <Setter Property="Foreground" Value="#3A3A3A"/>
        <!-- dark grey -->

        <!-- BASE -->
        <Setter Property="Background" Value="#FAF9F6"/>
        <!-- soft cream -->
        <Setter Property="BorderBrush" Value="#D6D3CE"/>
        <!-- light grey border -->
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="MinWidth" Value="95"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Border x:Name="bd"
                        CornerRadius="8"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}">

                        <ContentPresenter 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- 🔥 HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F0EEE9"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="#BFBFBF"/>
                        </Trigger>

                        <!-- 🔥 ACTIVE -->
                        <Trigger Property="Tag" Value="Active">
                            <Setter TargetName="bd" Property="Background" Value="#2F2F2F"/>
                            <!-- dark grey -->
                            <Setter TargetName="bd" Property="BorderBrush" Value="#1F1F1F"/>
                            <Setter Property="Foreground" Value="#FAF9F6"/>
                            <!-- cream text -->
                        </Trigger>

                        <!-- 🔥 CLICK -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#1F1F1F"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="JogTextBoxStyle"
       TargetType="TextBox"
       BasedOn="{StaticResource SystemFieldTextBox}">   

        <!-- SIZE -->
        <Setter Property="Height" Value="26"/>
        <Setter Property="MinWidth" Value="160"/>
        <Setter Property="MaxWidth" Value="250"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>

        <!-- SPACING -->
        <Setter Property="Margin" Value="4,6"/>
        <Setter Property="Padding" Value="6,2"/>

        <!-- REMOVE DEFAULT BORDER -->
        <Setter Property="BorderThickness" Value="0"/>

        <!-- TEMPLATE -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">

                    <!-- 🔥 OUTER WHITE BORDER -->
                    <Border Background="White"
                        Padding="2"
                        CornerRadius="2">

                        <!-- INNER DARK BOX -->
                        <Border Background="#2E2E2E"
                            BorderBrush="#555"
                            BorderThickness="1"
                            CornerRadius="2">

                            <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="2"/>
                        </Border>

                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

