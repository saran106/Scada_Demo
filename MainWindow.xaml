<Window x:Class="Scada_Demo.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Scada_Demo.Converters"
            xmlns:viewModels="clr-namespace:Scada_Demo.ViewModels"
            Title="SCADA Demo"
            Icon="C:\Users\ADMIN\Downloads\download-removebg-preview.png"
            Background="{StaticResource PrimaryBgBrush}"
            WindowStartupLocation="CenterScreen"
            WindowState="Maximized">


    <Window.Resources>
        <local:LevelToHeightConverter x:Key="LevelToHeightConverter"/>
        <local:LevelToTopConverter x:Key="LevelToTopConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:GateStatusToColorConverter x:Key="GateStatusToColorConverter"/>
        <local:GateStatusToForegroundConverter x:Key="GateStatusToForegroundConverter"/>
        <Storyboard x:Key="VanMoveAnimation" RepeatBehavior="Forever" AutoReverse="True">

            <DoubleAnimation 
        Storyboard.TargetName="CargoVanCanvas" 
        Storyboard.TargetProperty="(Canvas.Left)" 
        From="380" To="170"
        Duration="0:0:9"/>

            <DoubleAnimation 
        Storyboard.TargetName="CargoVanCanvas" 
        Storyboard.TargetProperty="(Canvas.Top)"  
        From="75" To="410"
        Duration="0:0:9"/>

        </Storyboard>



    </Window.Resources>





    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource VanMoveAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Window.DataContext>
        <viewModels:PlantViewModel/>
    </Window.DataContext>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SideMenuColumn" Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="SideMenu"
      Grid.Column="0"
      Background="#0B1F1F"
      Panel.ZIndex="100">

            <Border Background="#0B1F1F"
            BorderBrush="#00FFFF"
            BorderThickness="0,0,1,0">

                <StackPanel>

                    <!-- 🔥 HAMBURGER -->
                    <ToggleButton x:Name="MenuToggle"
                          Content="☰"
                          Width="45"
                          Height="45"
                          Margin="10"
                          FontSize="20"
                          Foreground="#00FFFF"
                          Background="Transparent"
                          BorderBrush="Transparent"
                          Cursor="Hand"
                          Click="MenuToggle_Click">

                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="bg"
                                            CornerRadius="6"
                                            Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#123F3F"/>
                                                </Trigger>

                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#1F5F5F"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>


                    <!-- MENU ITEMS -->
                    <StackPanel Margin="5,20,5,0">

                        <!-- 🔹 COMMON STYLE -->
                        <StackPanel.Resources>

                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                                <Setter Property="Margin" Value="5"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="Cursor" Value="Hand"/>

                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>

                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#123F3F"/>
                                        <Setter Property="BorderBrush" Value="#00FFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>

                                        <!-- Slight zoom -->
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>

                                </Style.Triggers>
                            </Style>

                        </StackPanel.Resources>

                        <!-- DASHBOARD -->
                        <Border MouseLeftButtonDown="Dashboard_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <TextBlock Text="🏠"
                                   FontSize="18"
                                   Foreground="#00FFFF"
                                   VerticalAlignment="Center"/>

                                <TextBlock Text="Dashboard"
                                   Margin="12,0,0,0"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"
                                   x:Name="TxtDashboard"/>
                            </StackPanel>
                        </Border>

                        <!-- USER -->
                        <Border MouseLeftButtonDown="Dashboard_Click1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <TextBlock Text="👤"
                                   FontSize="18"
                                   Foreground="#00FFFF"
                                   VerticalAlignment="Center"/>

                                <TextBlock Text="User"
                                   Margin="12,0,0,0"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"
                                   x:Name="TxtUser"/>
                            </StackPanel>
                        </Border>
                        
                        

                    </StackPanel>

                </StackPanel>
            </Border>
