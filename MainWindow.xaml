<Window x:Class="Scada_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:local="clr-namespace:Scada_Demo.Converters"
        xmlns:viewModels="clr-namespace:Scada_Demo.ViewModels"
        Title="SCADA Demo"
        Background="#0F2A2A"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">


    <Window.Resources>
        <local:LevelToHeightConverter x:Key="LevelToHeightConverter"/>
        <local:LevelToTopConverter x:Key="LevelToTopConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:GateStatusToColorConverter x:Key="GateStatusToColorConverter"/>
        <local:GateStatusToForegroundConverter x:Key="GateStatusToForegroundConverter"/>
        <Storyboard x:Key="VanMoveAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <!-- Adjust these To values based on where rectangle is -->
            <DoubleAnimation 
            Storyboard.TargetName="CargoVanCanvas" 
            Storyboard.TargetProperty="(Canvas.Left)" 
            From="250" 
            To="580"
                Duration="0:0:10"/>

            <DoubleAnimation 
            Storyboard.TargetName="CargoVanCanvas" 
            Storyboard.TargetProperty="(Canvas.Top)"  
            From="75" 
           To="550"     
                    Duration="0:0:10"/>
        </Storyboard>



    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource VanMoveAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Window.DataContext>
        <viewModels:PlantViewModel/>
    </Window.DataContext>

