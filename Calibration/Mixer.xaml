<Window x:Class="Scada_Demo.Calibration.Mixer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MC460 Mixer Calibration"
        SizeToContent="WidthAndHeight"
        MaxWidth="380"
        Background="{StaticResource PrimaryBgBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="10">

        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                Padding="15"
                CornerRadius="10">

            <Grid>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 🔥 FORM -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <!-- LABELS -->
                    <TextBlock Text="Mixer empty value"
                               Style="{StaticResource LabelStyle}"
                               FontSize="13"/>

                    <TextBlock Text="Mixer full scale value"
                               Grid.Row="1"
                               Style="{StaticResource LabelStyle}"
                               FontSize="13"/>

                    <TextBlock Text="Mixer actual value"
                               Grid.Row="2"
                               Style="{StaticResource LabelStyle}"
                               FontSize="13"/>

                    <!-- INPUTS -->
                    <TextBox Grid.Column="1"
                             Width="140"
                             Height="28"
                             Margin="5"
                             Style="{StaticResource SystemFieldTextBox}"/>

                    <TextBox Grid.Row="1" Grid.Column="1"
                             Width="140"
                             Height="28"
                             Margin="5"
                             Style="{StaticResource SystemFieldTextBox}"/>

                    <TextBox Grid.Row="2" Grid.Column="1"
                             Width="140"
                             Height="28"
                             Margin="5"
                             Style="{StaticResource SystemFieldTextBox}"/>

                </Grid>

                <!-- 🔥 BUTTONS -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0">

                    <Button Content="Set Empty" Width="90"/>
                    <Button Content="Set Full" Width="90"/>
                    <Button Content="Exit" Width="90" Style="{StaticResource RedButton}"/>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>