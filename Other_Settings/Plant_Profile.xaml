<Window x:Class="Scada_Demo.Other_Settings.Plant_Profile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plant_Profile"
        Height="650" Width="520"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Plant Profile"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Margin="10,10,10,35"
                Padding="10"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <!-- COLUMNS -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1 -->
                <TextBlock Text="Plant serial number"
                           Grid.Row="0"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 2 -->
                <TextBlock Text="Plant model / type"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          Margin="6,5,0,5"
                          Style="{StaticResource CompactComboBoxSmall}" MinWidth="0" Width="163" Height="30"/>

                <!-- 3 -->
                <TextBlock Text="Other plant capacity"
                           Grid.Row="2"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Margin="0,10,0,0"
                         Text="NA"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 4 -->
                <TextBlock Text="Company name"
                           Grid.Row="3"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Margin="0,10,0,0"
                         Text="SCHWING Stetter (India) Pvt. Ltd"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 5 -->
                <TextBlock Text="Plant code / Asset code"
                           Grid.Row="4"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Margin="0,10,0,0"
                         Text="-"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 6 -->
                <TextBlock Text="Auto header"
                           Grid.Row="5"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                         Margin="0,10,0,0"
                         Text="-"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 7 -->
                <TextBlock Text="TCP/IP port number"
                           Grid.Row="6"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="6" Grid.Column="1"
                         Margin="0,10,0,0"
                         Text="0"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 8 -->
                <TextBlock Text="Batch No / Ticket No"
                           Grid.Row="7"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}" />
                <TextBox Grid.Row="7" Grid.Column="1"
                         Margin="0,10,0,0"
                         Text="0"
                         Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="250" Height="34"/>

                <!-- 9 (Textbox + Button) -->
                <TextBlock Text="Custom Logo Location"
                           Grid.Row="8"
                           Margin="0,10,0,0"
                           Style="{StaticResource CompactLabel}"/>

                <Grid Grid.Row="8" Grid.Column="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="NA"
                             Style="{StaticResource JogTextBoxStyle}" MinWidth="0" Width="100" Height="30" Margin="6,0,56,12"/>

                    <Button Grid.Column="1"
                            Content="Upload"
                            Width="90" Margin="0,0,10,14"
                            />
                </Grid>

            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Save"
                    Width="130"
                    Margin="8"/>

            <Button Content="Exit"
                    Width="110"
                    Margin="8"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>