<Window x:Class="Scada_Demo.Other_Settings.Enable_Disable_OtherModes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enable_Disable_OtherModes"
        Height="600" Width="900"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <!-- MAIN -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Other settings"
                   Style="{StaticResource HeaderTextStyle}"
                   Margin="10,5"/>

        <Border Grid.Row="1"
        Margin="10"
        Padding="20"
        Background="{StaticResource PanelBrush}"
        BorderBrush="{StaticResource BorderBrushColor}"
        BorderThickness="2"
        CornerRadius="6">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10">

                <!-- 🔥 PERFECT COLUMN STRUCTURE -->
                <Grid.ColumnDefinitions>

                    <!-- LEFT SIDE -->
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="2.2*"/>

                    <!-- CENTER GAP -->
                    <ColumnDefinition Width="40"/>

                    <!-- RIGHT SIDE -->
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="2.2*"/>

                </Grid.ColumnDefinitions>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= ROW 0 ================= -->
                <TextBlock Text="Printer" Grid.Row="0" Grid.Column="0" Style="{StaticResource CompactLabel}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0"
          Grid.Column="2"
          Style="{StaticResource CompactComboBoxSmall}"
          Width="170"
        
          >

                        <ComboBoxItem Content="Auto"/>
                        <ComboBoxItem Content="Manual"/>
                        <ComboBoxItem Content="Semi Auto"/>
                        <ComboBoxItem Content="Batch Mode"/>
                        <ComboBoxItem Content="Continuous"/>
                        <ComboBoxItem Content="Test Mode"/>

                    </ComboBox>

                    <TextBlock Text="Gender" Grid.Row="0" Grid.Column="4" Style="{StaticResource CompactLabel}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 1 ================= -->
                <TextBlock Text="Batching mode" Grid.Row="1" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="1" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="No of gates for aggregate" Grid.Row="1" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="1" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 2 ================= -->
                <TextBlock Text="Teach mode" Grid.Row="2" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="2" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Secondary DB" Grid.Row="2" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="2" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 3 ================= -->
                <TextBlock Text="Plant type" Grid.Row="3" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="3" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Cloud Solution" Grid.Row="3" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="3" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 4 ================= -->
                <TextBlock Text="Aggregate weigher type" Grid.Row="4" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="4" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Consistency Graph" Grid.Row="4" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="4" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 5 ================= -->
                <TextBlock Text="Aggregate traverse mode" Grid.Row="5" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="5" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Precast Mode" Grid.Row="5" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="5" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 6 ================= -->
                <TextBlock Text="SMS batch data mode" Grid.Row="6" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="6" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Barcode in Report" Grid.Row="6" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="6" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 7 ================= -->
                <TextBlock Text="SMS Alarm / Production" Grid.Row="7" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="7" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Cumulative Batch Report" Grid.Row="7" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="7" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 8 ================= -->
                <TextBlock Text="Generic Interfacing / LD" Grid.Row="8" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="8" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="No. of Cements" Grid.Row="8" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="8" Grid.Column="6" Style="{StaticResource CompactTextBox}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 9 ================= -->
                <TextBlock Text="SMS weighbridge details" Grid.Row="9" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="9" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Crystalline mode" Grid.Row="9" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="9" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 10 ================= -->
                <TextBlock Text="Bridge weight in report" Grid.Row="10" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="10" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Ice Discharge Skip Mode" Grid.Row="10" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="10" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <!-- ================= ROW 11 ================= -->
                <TextBlock Text="Voice Alarm" Grid.Row="11" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="11" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>

                <TextBlock Text="Ice Discharge IBC Mode" Grid.Row="11" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="11" Grid.Column="6" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>


                <TextBlock Text="No of Copies to Print Alarm" Grid.Row="12" Grid.Column="0" Style="{StaticResource CompactLabel}"/>
                <ComboBox Grid.Row="12" Grid.Column="2" Style="{StaticResource CompactComboBoxSmall}" Margin="4,6" MinWidth="0" Width="170"/>


            </Grid>
            </ScrollViewer>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Read from PLC" Width="150"/>
            <Button Content="Write to PLC / DB" Width="170"/>
            <Button Content="Exit"
                    Width="110"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>