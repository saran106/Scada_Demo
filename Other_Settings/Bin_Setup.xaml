<Window x:Class="Scada_Demo.Other_Settings.Bin_Setup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scada_Demo.Other_Settings"
        mc:Ignorable="d"
        Title="Bin_Setup" Height="680" Width="720"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <TextBlock Text="Bin Settings"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- ================= CONTENT ================= -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">
            <Grid>

                <!-- COLUMNS -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2.5*"/>

                    <ColumnDefinition Width="30"/>

                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2.5*"/>
                </Grid.ColumnDefinitions>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 7 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 8 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9 -->
                </Grid.RowDefinitions>

                <!-- ================= LEFT SIDE ================= -->

                <!-- Agg1 -->
                <TextBlock Text="Aggregate1 Name" Grid.Row="0" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Agg2 -->
                <TextBlock Text="Aggregate2 Name" Grid.Row="1" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Agg3 -->
                <TextBlock Text="Aggregate3 Name" Grid.Row="2" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Agg4 -->
                <TextBlock Text="Aggregate4 Name" Grid.Row="3" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Agg5 -->
                <TextBlock Text="Aggregate5 Name" Grid.Row="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Agg6 -->
                <TextBlock Text="Aggregate6 Name" Grid.Row="5" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="5" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Cement1 -->
                <TextBlock Text="Cement1 Name" Grid.Row="6" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="6" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Cement2 -->
                <TextBlock Text="Cement2 Name" Grid.Row="7" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="7" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Cement3 -->
                <TextBlock Text="Cement3 Name" Grid.Row="8" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="8" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Cement4 -->
                <TextBlock Text="Cement4 Name" Grid.Row="9" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="9" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>


                <!-- ================= RIGHT SIDE ================= -->

                <!-- Cement5 -->
                <TextBlock Text="Cement5 Name" Grid.Row="0" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Water1 -->
                <TextBlock Text="Water1 Name" Grid.Row="1" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="1" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" MinWidth="0" Width="160"/>

                <!-- Water2 -->
                <TextBlock Text="Water2 Name" Grid.Row="2" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34"  MinWidth="0" Width="160"/>

                <!-- Water3 -->
                <TextBlock Text="Water3 Name" Grid.Row="3" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="3" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" Text="Wtr3" MinWidth="0" Width="160"/>

                <!-- Admix1 -->
                <TextBlock Text="Admixture1 Name" Grid.Row="4" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="4" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" Text="Admix1" MinWidth="0" Width="160"/>

                <!-- Admix2 -->
                <TextBlock Text="Admixture2 Name" Grid.Row="5" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="5" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" Text="Admix2" MinWidth="0" Width="160"/>

                <!-- Admix3 -->
                <TextBlock Text="Admixture3 Name" Grid.Row="6" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="6" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" Text="Admix3" MinWidth="0" Width="160"/>

                <!-- Admix4 -->
                <TextBlock Text="Admixture4 Name" Grid.Row="7" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="7" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" Text="Admix4" MinWidth="0" Width="160"/>

                <!-- Silica -->
                <TextBlock Text="Silica Name" Grid.Row="8" Grid.Column="4" Style="{StaticResource CompactLabel}"/>
                <TextBox Grid.Row="8" Grid.Column="6" Style="{StaticResource JogTextBoxStyle}" Height="34" Text="Silica" MinWidth="0" Width="160"/>

            </Grid>
        </Border>

        <!-- ================= BUTTONS ================= -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Save"
                    Width="150"
                    Margin="8"/>


            <Button Content="Exit"
                    Width="110"
                    Margin="8"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>