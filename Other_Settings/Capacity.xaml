<Window x:Class="Scada_Demo.Other_Settings.Capacity"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capacity"
        Height="520" Width="650"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Weigher / hopper capacity settings"
                   Margin="10"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- 1 -->
                    <TextBlock Text="Aggregate capacity in kg" Grid.Row="0" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 2 -->
                    <TextBlock Text="Cement capacity in kg" Grid.Row="1" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 3 -->
                    <TextBlock Text="Water capacity in kg" Grid.Row="2" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 4 -->
                    <TextBlock Text="Water 2 / ice capacity in kg" Grid.Row="3" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 5 -->
                    <TextBlock Text="Admixture 1 &amp; 2 capacity in kg" Grid.Row="4" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 6 -->
                    <TextBlock Text="Admixture 3 &amp; 4 capacity in kg" Grid.Row="5" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 7 -->
                    <TextBlock Text="Silica capacity in kg" Grid.Row="6" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 8 -->
                    <TextBlock Text="Crystalline capacity in kg" Grid.Row="7" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="7" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 9 -->
                    <TextBlock Text="Silo 1 Capacity in Tons" Grid.Row="8" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="8" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 10 -->
                    <TextBlock Text="Silo 2 Capacity in Tons" Grid.Row="9" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="9" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 11 -->
                    <TextBlock Text="Silo 3 Capacity in Tons" Grid.Row="10" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="10" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 12 -->
                    <TextBlock Text="Silo 4 Capacity in Tons" Grid.Row="11" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="11" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                    <!-- 13 -->
                    <TextBlock Text="Silo 5 Capacity in Tons" Grid.Row="12" Style="{StaticResource CompactLabel}"/>
                    <TextBox Grid.Row="12" Grid.Column="2" Style="{StaticResource JogTextBoxStyle}" Height="34"/>

                </Grid>

            </ScrollViewer>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Read from PLC" Width="150" Margin="8"/>
            <Button Content="Write to PLC / DB" Width="180" Margin="8"/>
            <Button Content="Exit" Width="110" Margin="8"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>