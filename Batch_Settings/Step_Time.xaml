<Window x:Class="Scada_Demo.Batch_Settings.Step_Time"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Step_Time"
        Height="420" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBgBrush}">

    <Grid Margin="8">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Step Time"
                   Margin="5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- TABS -->
        <StackPanel x:Name="TabButtons"
                    Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="5">

            <Button Content="Aggregate" Style="{StaticResource TabButtonStyle}" Click="ShowAggregate"/>
            <Button Content="Cement" Style="{StaticResource TabButtonStyle}" Click="ShowCement"/>
            <Button Content="Water" Style="{StaticResource TabButtonStyle}" Click="ShowWater"/>
            <Button Content="Admixture" Style="{StaticResource TabButtonStyle}" Click="ShowAdmix"/>
            <Button Content="Micro Silica" Style="{StaticResource TabButtonStyle}" Click="ShowSilica"/>

        </StackPanel>

        <!-- CONTENT -->
        <Border Grid.Row="2"
                Margin="5"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <!-- ================= AGG ================= -->
                <Grid x:Name="AggregatePanel" Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- LEFT -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Agg1" Width="70" Style="{StaticResource CompactLabel}"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Agg2" Width="70" Style="{StaticResource CompactLabel}"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Agg3" Width="70" Style="{StaticResource CompactLabel}"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- RIGHT -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Agg4" Width="70" Style="{StaticResource CompactLabel}"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Agg5" Width="70" Style="{StaticResource CompactLabel}"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Agg6" Width="70" Style="{StaticResource CompactLabel}"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                </Grid>

                <!-- ================= CEMENT ================= -->
                <Grid x:Name="CementPanel" Visibility="Collapsed" Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Cem1" Width="70"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Cem2" Width="70"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Cem3" Width="70"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Cem4" Width="70"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Cem5" Width="70"/>
                        <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                        <TextBlock Text="sec" Margin="10,0,0,0"/>
                    </StackPanel>

                </Grid>

                <!-- WATER -->
                <Grid x:Name="WaterPanel" Visibility="Collapsed" Margin="10">

                    <StackPanel Orientation="Vertical">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Wtr1" Width="70"/>
                            <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                            <TextBlock Text="sec" Margin="10,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Wtr2" Width="70"/>
                            <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                            <TextBlock Text="sec" Margin="10,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Wtr3" Width="70"/>
                            <TextBox Width="120" Style="{StaticResource JogTextBoxStyle}"/>
                            <TextBlock Text="sec" Margin="10,0,0,0"/>
                        </StackPanel>

                    </StackPanel>

                </Grid>

                <!-- ADMIX -->
                <Grid x:Name="AdmixPanel" Visibility="Collapsed" Margin="10">



                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- Admix1 -->
                    <StackPanel Grid.Row="0" Grid.Column="0"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                        <TextBlock Text="Admix1"
               Width="70"
               Style="{StaticResource CompactLabel}"/>

                        <TextBox Style="{StaticResource JogTextBoxStyle}"
             Width="120"/>

                        <TextBlock Text="sec"
               Margin="10,0,0,0"
               Style="{StaticResource CompactLabel}"/>
                    </StackPanel>

                    <!-- Admix2 -->
                    <StackPanel Grid.Row="1" Grid.Column="0"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                        <TextBlock Text="Admix2"
               Width="70"
               Style="{StaticResource CompactLabel}"/>

                        <TextBox Style="{StaticResource JogTextBoxStyle}"
             Width="120"/>

                        <TextBlock Text="sec"
               Margin="10,0,0,0"
               Style="{StaticResource CompactLabel}"/>
                    </StackPanel>

                    <!-- Admix3 -->
                    <StackPanel Grid.Row="0" Grid.Column="2"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                        <TextBlock Text="Admix3"
               Width="70"
               Style="{StaticResource CompactLabel}"/>

                        <TextBox Style="{StaticResource JogTextBoxStyle}"
             Width="120"/>

                        <TextBlock Text="sec"
               Margin="10,0,0,0"
               Style="{StaticResource CompactLabel}"/>
                    </StackPanel>

                    <!-- Admix4 -->
                    <StackPanel Grid.Row="1" Grid.Column="2"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                        <TextBlock Text="Admix4"
               Width="70"
               Style="{StaticResource CompactLabel}"/>

                        <TextBox Style="{StaticResource JogTextBoxStyle}"
             Width="120"/>

                        <TextBlock Text="sec"
               Margin="10,0,0,0"
               Style="{StaticResource CompactLabel}"/>
                    </StackPanel>

                </Grid>

                <!-- SILICA -->
                <Grid x:Name="SilicaPanel" Visibility="Collapsed" Margin="10">
                    <StackPanel Grid.Row="0" Grid.Column="0"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                        <TextBlock Text="Silica"
               Width="70"
               Style="{StaticResource CompactLabel}"/>

                        <TextBox Style="{StaticResource JogTextBoxStyle}"
             Width="120"/>

                        <TextBlock Text="sec"
               Margin="10,0,0,0"
               Style="{StaticResource CompactLabel}"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button Content="Read from PLC" Width="130"/>
            <Button Content="Write to PLC / DB" Width="160"/>
            <Button Content="Exit" Width="100" Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>