<Window x:Class="Scada_Demo.Options.Reconcilation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scada_Demo.Options"
        mc:Ignorable="d"
        Title="Reconcilation" Height="450" Width="520"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">


    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <TextBlock Text="Adjustment"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- ================= CONTENT ================= -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Product Name -->
                <TextBlock Text="Product name"
                           Grid.Row="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <ComboBox Grid.Row="0" Grid.Column="1"
                          Style="{StaticResource CompactComboBoxSmall}" Grid.ColumnSpan="2" Margin="20,16,0,0"/>

                <!-- Adjusted Stock -->
                <TextBlock Text="Adjusted stock value"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="1" Grid.Column="1"
                         Margin="20,10,30,0"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="34" Grid.ColumnSpan="2"/>

                <!-- Remark -->
                <TextBlock Text="Remark"
                           Grid.Row="2"
                           Margin="0,10,0,0"
                           VerticalAlignment="Top"
                           Style="{StaticResource CompactLabel}"/>

                <TextBox Grid.Row="2" Grid.Column="2"
                         Margin="0,10,0,0"
                         Style="{StaticResource JogTextBoxStyle}"
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- From Date -->
                <TextBlock Text="From Date"
                           Grid.Row="3"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <DatePicker Grid.Row="3" Grid.Column="2"
                            Margin="0,10,0,0"
                            Height="34"/>

            </Grid>
        </Border>

        <!-- ================= BUTTONS ================= -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Save"
                    Width="140"
                    Margin="10"
                   />

            <Button Content="Exit"
                    Width="140"
                    Margin="10"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>
