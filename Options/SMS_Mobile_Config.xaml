<Window x:Class="Scada_Demo.Options.SMS_Mobile_Config"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMS Mobile Config" Height="400" Width="800">

    <Grid Background="{StaticResource PrimaryBgBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT PANEL ================= -->
        <Border Grid.Column="0" Margin="10"
                Background="{StaticResource PanelBrush}">

            <StackPanel Margin="10">

                <TextBlock Text="Configure Mobile for Alarm"
                           Style="{StaticResource HeaderTextStyle}"/>

                <TextBlock Text="Mobile No:" Style="{StaticResource CompactLabel}"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtAlarmMobile"
                             Style="{StaticResource HeaderTextBoxStyle}"
                             Width="200"/>

                    <Button Content="+"
                            Width="35"
                            />
                </StackPanel>

                <ListBox x:Name="lstAlarmMobiles"
                         Height="160"
                         Background="Black"
                         Foreground="White"
                         BorderBrush="White"
         BorderThickness="2"/>

                <Button Content="-"
                        Width="35"
                        HorizontalAlignment="Right"
                        Style="{StaticResource RedButton}"
                        />
            </StackPanel>
        </Border>

        <!-- ================= RIGHT PANEL ================= -->
        <Border Grid.Column="1" Margin="10"
                Background="{StaticResource PanelBrush}">

            <StackPanel Margin="10">

                <TextBlock Text="Configure Mobile for Production Details"
                           Style="{StaticResource HeaderTextStyle}"/>

                <TextBlock Text="Mobile No:" Style="{StaticResource CompactLabel}"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtProdMobile"
                             Style="{StaticResource HeaderTextBoxStyle}"
                             Width="200"/>

                    <Button Content="+"
                            Width="35"
                            />
                </StackPanel>

                <ListBox x:Name="lstProdMobiles"
                         Height="160"
                         Background="Black"
                         Foreground="White"
                         BorderBrush="White"
         BorderThickness="2"/>

                <Button Content="-"
                        Width="35"
                        HorizontalAlignment="Right"
                        Style="{StaticResource RedButton}"
                      />
            </StackPanel>
        </Border>

        <!-- ================= EXIT BUTTON ================= -->
        <Button Content="EXIT"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,15"
                Width="100"
                Style="{StaticResource SecondaryButton}"/>
    </Grid>
</Window>