<Window x:Class="Scada_Demo.Transactions.Divert_Concrete"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Divert_Concrete"
        Height="400" Width="400"
        Background="#0D3A3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">

        <!-- MAIN ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Divert Concrete"
                   Margin="10,5"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Margin="10"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="2"
                CornerRadius="6">

            <Grid>

                <!-- COLUMN STRUCTURE -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Batch No -->
                <TextBlock Text="Batch No"
                           Grid.Row="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <ComboBox Grid.Row="0" Grid.Column="2"
                          Style="{StaticResource CompactComboBoxSmall}" MinWidth="0" Width="160" Height="34" Margin="0,12,0,4"/>

                <!-- Sub Batch -->
                <TextBlock Text="Sub Batch No"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <ComboBox Grid.Row="1" Grid.Column="2"
                          Margin="0,10,0,0"
                          Style="{StaticResource CompactComboBoxSmall}" MinWidth="0" Width="160" Height="34"/>

                <!-- Customer -->
                <TextBlock Text="Customer"
                           Grid.Row="2"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <ComboBox Grid.Row="2" Grid.Column="2"
                          Margin="0,10,0,0"
                          Style="{StaticResource CompactComboBoxSmall}" MinWidth="0" Width="160" Height="34"/>

                <!-- Site -->
                <TextBlock Text="Site"
                           Grid.Row="3"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactLabel}"/>

                <ComboBox Grid.Row="3" Grid.Column="2"
                          Margin="0,10,0,0"
                          Style="{StaticResource CompactComboBoxSmall}" MinWidth="0" Width="160" Height="34"/>

            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Divert"
                    Width="140"
                    Margin="10"
                   />

            <Button Content="Exit"
                    Width="140"
                    Margin="10"
                    Style="{StaticResource RedButton}"/>

        </StackPanel>

    </Grid>
</Window>